// simple fibonacci test
const ten i8 10
const sixty-5-k ptr 0xffff

label main
    push ten
    call fib
    ret

label fib
    dup
    push i32 1
    gt
    jumpif fib_recurse
    ret

label fib_recurse
    dup
    push i32 1
    sub
    call fib
    swap
    push i32 2
    sub
    call fib
    add
    ret
