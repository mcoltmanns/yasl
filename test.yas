proc fib in i32 out i32 def
    // stack: n
    dup
    push i32 1
    leq
    jumpif fib_base     // if n <= 1 return n

    // fib(n-1)
    dup
    dec
    call fib            // stack: n fib(n-1)

    // fib(n-2)
    swap
    push i32 2
    sub
    call fib            // stack: fib(n-1) fib(n-2)

    add                 // stack: fib(n)
    ret

    label fib_base
        ret             // stack: n (which is 0 or 1)

proc main in out def
    push i32 10
    call fib
    // fib(10) = 55
    ret
