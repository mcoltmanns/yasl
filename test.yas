const one i32 1
push one
jump main

proc main in out def
    jump somewhere
    label real
    push i32 10
    call fib
    pop
    // fib(10) = 55
    ret
    label somewhere
    jump real

proc fib in i32 out i32 def
    // stack: n
    dup
    push one
    leq
    jumpif fib_base     // if n <= 1 return n

    // fib(n-1)
    dup
    dec
    call fib            // stack: n fib(n-1)

    // fib(n-2)
    swap
    push i32 2
    sub
    call fib            // stack: fib(n-1) fib(n-2)

    add                 // stack: fib(n)
    ret

    label fib_base
        ret             // stack: n (which is 0 or 1)

proc loop in out def
    label loop
    jump loop
    
